@page "/money/delete"
@using Abc.Data
@using Abc.Infra
@inject IMoneyRepo repo
@inject NavigationManager NavigationManager
@using Abc.Shared.Pages

<MyDeletePage PageTitleText="Delete Money" EntityTitle="Money" Entity="item" BasePath="/money" OnValidSubmit="delete" />

@code {
	private Money item;
	[SupplyParameterFromQuery] private Guid Id { get; set; }
	protected override async Task OnInitializedAsync() {
		item = await repo.GetAsync(Id);
		if (item is null) NavigationManager.NavigateTo("/404", true);
	}
	private async Task delete() {
		await repo.DeleteAsync(item!.Id);
		NavigationManager.NavigateTo("/money");
	}
}