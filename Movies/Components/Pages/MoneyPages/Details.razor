@page "/money/details"
@using Abc.Data
@using Abc.Infra
@inject IMoneyRepo repo
@inject NavigationManager NavigationManager
@using Abc.Shared.Pages

<MyDetailsPage
	PageTitleText="Details Money"
	EntityTitle="Money"
	Entity="item"
	EntityId="item?.Id"
	BasePath="/money" />

@code {
	private Money item;
	[SupplyParameterFromQuery] private Guid Id { get; set; }
	protected override async Task OnInitializedAsync() {
		item = await repo.GetAsync(Id);
		if (item is null) NavigationManager.NavigateTo("/404", true);
	}
}