@page "/money/edit"
@using Abc.Data
@using Abc.Infra
@inject IMoneyRepo repo
@inject NavigationManager NavigationManager
@using Abc.Shared.Pages

<MyEditPage 
	PageTitleText="Edit Money" 
	EntityTitle="Money" 
	Entity="money" 
	BasePath="/money"
	EntityId="@Id"
	OnValidSubmit="update" />

@code {
	[SupplyParameterFromQuery] private Guid Id { get; set; }
	[SupplyParameterFromForm(Name = nameof(Money))] private Money money { get; set; }
	protected override async Task OnInitializedAsync() {
		money ??= await repo.GetAsync(Id);
		if (money is null) NavigationManager.NavigateTo("/404", true);
	}
	private async Task update() {
		await repo.UpdateAsync(money!);
		NavigationManager.NavigateTo("/money");
	}
}