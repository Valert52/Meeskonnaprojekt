@page "/money/create"
@using Abc.Data
@using Abc.Infra
@inject IMoneyRepo repo
@inject NavigationManager NavigationManager
@using Abc.Shared.Pages

<MyCreatePage Entity="money" EntityTitle="Money" BasePath="/money" OnValidSubmit="add" />


@code {
	[SupplyParameterFromForm(Name = nameof(Money))] private Money money { get; set; } = default!;
	protected override void OnInitialized() => money ??= new();
	private async Task add() {
		await repo.CreateAsync(money);
		NavigationManager.NavigateTo("/money");
	}
}