@page "/movies/details"
@using Abc.Infra
@inject IMoviesRepo repo
@inject NavigationManager NavigationManager
@using Abc.Data
@using Abc.Shared.Pages

<MyDetailsPage
	PageTitleText="Details Movie"
	EntityTitle="Movie"
	Entity="movie"
	EntityId="movie?.Id"
	BasePath="/movies" />

@code {
	private Movie movie;
	[SupplyParameterFromQuery] private Guid Id { get; set; }
	protected override async Task OnInitializedAsync() {
		movie = await repo.GetAsync(Id);
		if (movie is null) NavigationManager.NavigateTo("/404");
	}
}