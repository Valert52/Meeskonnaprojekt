@page "/currencies/delete"
@using Abc.Data
@using Abc.Infra
@inject ICurrenciesRepo repo
@inject NavigationManager NavigationManager
@using Abc.Shared.Pages

<MyDeletePage PageTitleText="Delete Currency"
              EntityTitle="Currency"
              Entity="item"
              BasePath="/currencies"
              OnValidSubmit="delete" />

@code {
	private Currency item;
	[SupplyParameterFromQuery] private int Id { get; set; }

	protected override async Task OnInitializedAsync() {
		item = await repo.GetAsync(Id);
		if (item is null) {
			NavigationManager.NavigateTo("/404", true);
			return;
		}
	}

	private async Task delete() {
		await repo.DeleteAsync(item!.Id);
		NavigationManager.NavigateTo("/currencies");
	}
}