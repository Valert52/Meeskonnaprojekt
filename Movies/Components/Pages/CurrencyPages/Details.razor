@page "/currencies/details"
@using Abc.Data
@using Abc.Infra
@inject ICurrenciesRepo repo
@inject NavigationManager NavigationManager
@using Abc.Shared.Pages

<MyDetailsPage
	PageTitleText="Details Currency"
	EntityTitle="Currency"
	Entity="item"
	EntityId="item?.Id"
	BasePath="/currencies" />

@code {
	private Currency item;
	[SupplyParameterFromQuery] private int Id { get; set; }

	protected override async Task OnInitializedAsync() {
		item = await repo.GetAsync(Id);
		if (item is null) NavigationManager.NavigateTo("/404", true);
	}
}