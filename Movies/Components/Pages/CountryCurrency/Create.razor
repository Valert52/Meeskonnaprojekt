@using Abc.Data
@page "/countrycurrencies/create"
@using Abc.Infra
@inject ICountryCurrenciesRepo repo
@inject NavigationManager NavigationManager
@using Abc.Shared.Pages

<MyCreatePage
	Entity="item"
	EntityTitle="Country Currencies"
	BasePath="/countrycurrencies"
	OnValidSubmit="add" />

@code {
	[SupplyParameterFromForm(Name = nameof(CountryCurrency))]
	private CountryCurrency item { get; set; } = new();

	private async Task add() {
		await repo.CreateAsync(item);
		NavigationManager.NavigateTo("/countrycurrencies");
	}
}